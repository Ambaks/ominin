{"nodes": [{"id": "_claude_skills_graphify_skill_graphify_skill", "label": "/graphify Skill", "file_type": "document", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Turns any folder of code, docs, papers, images, or video into a persistent queryable knowledge graph with an honest EXTRACTED/INFERRED/AMBIGUOUS audit trail and community detection."}, {"id": "_claude_skills_graphify_skill_fast_path_query", "label": "Fast Path Query on Existing Graph", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "What You Must Do When Invoked", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json exists and the request is a natural-language question, skip the entire build pipeline and run graphify query directly \u2014 the graph is already built."}, {"id": "_claude_skills_graphify_skill_ast_extraction", "label": "AST Structural Extraction", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic and free: code is extracted structurally with no LLM and no API key, so a code-only corpus skips semantic extraction entirely."}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction via Parallel Subagents", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Docs, papers, and images need LLM extraction; general-purpose subagents dispatched in a single message run in parallel (5-10x faster than sequential reads), and read-only Explore agents silently drop results because they cannot write chunk files."}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0 \u2014 Check extraction cache", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Files already extracted are served from cache so only uncached files cost subagent tokens; stale cache files from prior runs are deleted so merges never include them."}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection and Clustering", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Communities surface cross-document connections you wouldn't think to ask about; each gets a 2-5 word plain-language label in Step 5."}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "God Nodes", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Highest-connectivity nodes reported in GRAPH_REPORT.md; also reused as domain hints for Whisper transcription."}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only integrity gate before labeling; surfaces dangling/missing endpoints, self-loops, and edge collapse \u2014 the silent-corruption modes of incremental updates and AST/LLM id mismatches \u2014 without aborting."}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Graph Shrink Guard", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json refuses to write a smaller graph over an existing graph.json (#479) so an empty or failed extraction never clobbers a good graph, report, or analysis sidecar."}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Honesty Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge (use AMBIGUOUS if unsure); always show token cost; show raw cohesion numbers; warn before visualizing graphs over 5,000 nodes."}, {"id": "_claude_skills_graphify_skill_cost_tracker", "label": "Cumulative Cost Tracker", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 9", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "cost.json accumulates per-run and all-time token counts so the token cost of graph building is always visible, per the Honesty Rules."}, {"id": "_claude_skills_graphify_skill_confidence_taxonomy", "label": "EXTRACTED/INFERRED/AMBIGUOUS Taxonomy", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every edge carries an audit tag so users can distinguish facts explicit in sources from inferences and flagged uncertainties."}], "edges": [{"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_skill_fast_path_query", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_skill_ast_extraction", "relation": "conceptually_